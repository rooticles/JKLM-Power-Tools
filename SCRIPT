                        <input type="password" class="custom-msg-input" id="admin-pass-input" placeholder="${t.adminPassPlaceholder}" style="min-height: 30px; margin-bottom: 10px;">
                        <button class="custom-msg-send" id="admin-login-btn" style="width: 100%;">${t.adminLoginBtn}</button>
                        <div id="admin-login-error" style="color: #ff4444; font-size: 12px; margin-top: 10px; display: none;">${t.adminLoginError}</div>
                    </div>
                    <div style="margin-top: 15px; padding-top: 8px; border-top: 1px solid #333; color: #666; font-size: 10px; font-style: italic;">${t.closeInfo}</div>
                `;
                return;
            }

            adminPage.innerHTML = `
                <div class="custom-kb-header">
                    <span>${t.adminHeader}</span>
                    <span class="custom-close-x" id="cat-admin-close">✕</span>
                </div>
                
                <div class="custom-msg-module">
                    <div style="font-weight: bold; color: #ccc; margin-bottom: 10px;">${t.adminMacrosHeader}</div>
                    <div style="display: flex; flex-wrap: wrap; gap: 5px; margin-top: 5px;">
                        <button class="custom-macro-btn" data-msg="GG">GG</button>
                        <button class="custom-macro-btn" data-msg="Nice word!">Nice!</button>
                        <button class="custom-macro-btn" data-msg="WP">WP</button>
                        <button class="custom-macro-btn" data-msg="GL HF">GL HF</button>
                    </div>
                </div>

                <div class="custom-msg-module">
                    <div style="font-weight: bold; color: #ccc; margin-bottom: 10px;">${t.adminVisualHeader}</div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                        <span>${t.adminThemeLabel}</span>
                        <input type="color" class="custom-theme-picker" id="admin-theme-picker" value="${themeColor}">
                    </div>
                </div>

                <div style="margin-top: 15px; padding-top: 8px; border-top: 1px solid #333; color: #666; font-size: 10px; font-style: italic;">${t.closeInfo}</div>
            `;
        };

        updateKbContent();
        updateLangContent();
        updateDictContent();
        updateStatsContent();
        updateAdminContent();

        const resizer = document.createElement('div');
        resizer.className = 'custom-resizer';
        resizer.style.display = 'none';

        const updateSidebarWidths = (width) => {
            allCustomPages.forEach(p => p.style.width = `${width}px`);
            resizer.style.left = '0';
        };
        updateSidebarWidths(getSidebarWidth());

        let isResizing = false;
        resizer.addEventListener('mousedown', (e) => {
            isResizing = true;
            resizer.classList.add('resizing');
            document.body.style.cursor = 'ew-resize';
            e.preventDefault();
        });

        window.addEventListener('mousemove', (e) => {
            if (!isResizing) return;
            const rect = kbPage.getBoundingClientRect();
            const newWidth = rect.right - e.clientX;
            if (newWidth >= 250 && newWidth <= 800) {
                updateSidebarWidths(newWidth);
                setSidebarWidth(newWidth);
            }
        });

        window.addEventListener('mouseup', () => {
            if (isResizing) {
                isResizing = false;
                resizer.classList.remove('resizing');
                document.body.style.cursor = '';
            }
        });

        const pages = document.querySelector('.pages') || main;
        if (pages) pages.style.backgroundColor = '#1a1a1a';
        allCustomPages.forEach(p => pages.appendChild(p));
        pages.appendChild(resizer);

        window.closeCustomTabs = () => {
            [catTab, flagTab, dictTab, statsTab, adminTab].forEach(t => t.classList.remove('active'));
            allCustomPages.forEach(p => p.classList.remove('active'));
            resizer.style.display = 'none';
            const home = nav.querySelector('[data-tab="home"]') || nav.querySelector('.tab');
            if (home && ![catTab, flagTab, dictTab, statsTab, adminTab].includes(home)) home.click();
        };

        const toggleTab = (tab, page) => {
            const isActive = tab.classList.contains('active');
            
            // Close if clicking the same active tab
            if (isActive) {
                window.closeCustomTabs();
                return;
            }

            document.querySelectorAll('.page, .tab').forEach(el => el.classList.remove('active'));
            allCustomPages.forEach(p => p.classList.remove('active'));
            
            tab.classList.add('active');
            page.classList.add('active');
            resizer.style.display = 'block';
            if (page === dictPage) loadDictionary();
        };

        catTab.addEventListener('click', () => toggleTab(catTab, kbPage));
        flagTab.addEventListener('click', () => toggleTab(flagTab, langPage));
        dictTab.addEventListener('click', () => toggleTab(dictTab, dictPage));
        statsTab.addEventListener('click', () => { updateStatsContent(); toggleTab(statsTab, statsPage); });
        adminTab.addEventListener('click', () => { updateAdminContent(); toggleTab(adminTab, adminPage); });

        nav.addEventListener('click', (e) => {
            const clicked = e.target.closest('.tab');
            if (clicked && ![catTab, flagTab, dictTab, statsTab, adminTab].includes(clicked)) {
                allCustomPages.forEach(p => p.classList.remove('active'));
                [catTab, flagTab, dictTab, statsTab, adminTab].forEach(t => t.classList.remove('active'));
                resizer.style.display = 'none';
            }
        });

        kbPage.addEventListener('click', (e) => {
            if (e.target.id === 'cat-kb-close') window.closeCustomTabs();
            const toggle = e.target.closest('.toggle-switch');
            if (!toggle) return;
            if (toggle.closest('#toggle-space-hyphen')) setEnabled(!getEnabled());
            if (toggle.closest('#toggle-chat-hyphen')) setChatEnabled(!getChatEnabled());
            updateKbContent();
        });

        langPage.addEventListener('click', (e) => {
            if (e.target.id === 'flag-lang-close') window.closeCustomTabs();
            const item = e.target.closest('.custom-lang-item');
            if (item) {
                setLanguage(item.getAttribute('data-lang'));
                updateLangContent(); updateKbContent(); updateDictContent(); updateAdminContent();
            }
        });

        const handleDictSearch = () => {
            const input = document.getElementById('dict-msg-input');
            const resultsContainer = document.getElementById('dict-results-container');
            const resultHeader = document.getElementById('dict-result-header');
            const resultList = document.getElementById('dict-result-list');
            if (!input || !input.value.trim()) return;

            let fullInput = input.value.trim();
            let syllable = fullInput;
            let lengthFilter = null;
            let customLength = null;
            let secondaryFilter = null;

            const inputParts = fullInput.split(' ').filter(p => p.length > 0);
            const cmd = inputParts[0].toLowerCase();

            if (['/s', '/short', '/shorts'].includes(cmd)) {
                lengthFilter = 'short'; syllable = inputParts.slice(1).join(' ').trim();
            } else if (['/l', '/long', '/longs'].includes(cmd)) {
                lengthFilter = 'long'; syllable = inputParts.slice(1).join(' ').trim();
            } else if (cmd === '/h' || cmd === '/hyphen' || cmd === '/hyphens') {
                lengthFilter = 'hyphen'; syllable = inputParts.slice(1).join(' ').trim();
            } else if (cmd === '/r' || cmd === '/rare') {
                lengthFilter = 'rare'; syllable = inputParts.slice(1).join(' ').trim();
            } else if (cmd === '/p') {
                lengthFilter = 'phobia'; syllable = inputParts.slice(1).join(' ').trim();
            } else if (cmd === '/a') {
                lengthFilter = 'apostrophe'; syllable = inputParts.slice(1).join(' ').trim();
            } else if (cmd === '/c') {
                lengthFilter = 'custom'; customLength = parseInt(inputParts[1], 10);
                const lastPart = inputParts[inputParts.length - 1];
                if (['-s', '-l', '-p', '-a', '-h', '-r'].includes(lastPart)) {
                    secondaryFilter = lastPart.substring(1); syllable = inputParts.slice(2, -1).join(' ').trim();
                } else {
                    syllable = inputParts.slice(2).join(' ').trim();
                }
            }

            const lang = getLanguage();
            const t = translations[lang] || translations['Deutsch'];

            loadDictionary().then(() => {
                let words = syllable ? findWords(syllable) : [...dictionary];
                
                // Filter out used words
                words = words.filter(w => !usedWords.includes(w.toUpperCase()));

                if (lengthFilter === 'short' || secondaryFilter === 's') words = words.filter(w => w.length >= 2 && w.length <= 5);
                if (lengthFilter === 'long' || secondaryFilter === 'l') words = words.filter(w => w.length >= 20 && w.length <= 30);
                if (lengthFilter === 'hyphen' || secondaryFilter === 'h') words = words.filter(w => w.includes('-'));
                if (lengthFilter === 'rare' || secondaryFilter === 'r') {
                    const rareChars = lang === 'Deutsch' ? ['x', 'y', 'q', 'z', 'v'] : ['x', 'q', 'z', 'j', 'v'];
                    words = words.filter(w => {
                        const low = w.toLowerCase();
                        return w.length > 10 || rareChars.some(c => low.includes(c));
                    });
                }
                if (lengthFilter === 'phobia' || secondaryFilter === 'p') words = words.filter(w => { const low = w.toLowerCase(); return low.includes('phobia') || low.includes('phobias') || low.includes('phobic'); });
                if (lengthFilter === 'apostrophe' || secondaryFilter === 'a') words = words.filter(w => w.includes("'"));
                if (lengthFilter === 'custom' && customLength > 0) words = words.filter(w => w.length === customLength);

                resultsContainer.classList.add('active');
                if (words.length > 0) {
                    const shuffled = shuffleArray([...words]).slice(0, 9);
                    let header = syllable ? t.dictResultPrefix.replace('{count}', words.length).replace('{syllable}', syllable.toUpperCase()) : `Found ${words.length} words:`;
                    if (lengthFilter === 'custom') header += ` (Länge: ${customLength})`;
                    resultHeader.innerText = header;
                    resultList.innerHTML = shuffled.map(w => `<span class="clickable-word" title="Click to copy">${w.toUpperCase()}</span>`).join(' – ');
                } else {
                    resultHeader.innerText = syllable ? t.dictNoResults.replace('{syllable}', syllable.toUpperCase()) : 'No results.';
                    resultList.innerHTML = '';
                }
                input.value = '';
            });
        };

        statsPage.addEventListener('click', (e) => {
            if (e.target.id === 'stats-close') window.closeCustomTabs();
            if (e.target.id === 'stats-reset-btn') {
                if (confirm('Möchtest du wirklich alle Statistiken zurücksetzen?')) {
                    setStats({ totalWords: 0, longestWord: '', responseTimes: [] });
                    updateStatsContent();
                }
            }
        });

        dictPage.addEventListener('click', (e) => {
            if (e.target.id === 'dict-close') window.closeCustomTabs();
            if (e.target.id === 'dict-msg-send') handleDictSearch();
            
            if (e.target.classList.contains('clickable-word')) {
                const word = e.target.innerText;
                navigator.clipboard.writeText(word).then(() => {
                    const originalColor = e.target.style.color;
                    e.target.style.color = 'var(--theme-color)';
                    setTimeout(() => e.target.style.color = originalColor, 500);
                });
            }
        });
        dictPage.addEventListener('change', (e) => {
            if (e.target.id === 'dict-lang-select') {
                setDictLanguage(e.target.value);
                dictionaryLoaded = false;
                loadDictionary(true).then(() => updateDictContent());
            }
        });
        dictPage.addEventListener('keydown', (e) => { if (e.key === 'Enter' && e.target.id === 'dict-msg-input') { e.preventDefault(); handleDictSearch(); } });

       adminPage.addEventListener('click', (e) => {
            if (e.target.id === 'cat-admin-close') { window.closeCustomTabs(); return; }

            if (e.target.id === 'admin-login-btn') {
                const user = document.getElementById('admin-user-input').value;
                const pass = document.getElementById('admin-pass-input').value;
                const error = document.getElementById('admin-login-error');

                if (adminUsers[user] && adminUsers[user] === pass) {
                    isAdminAuthenticated = true;
                    setAdminAuth(true);
                    updateAdminContent();
                } else {
                    error.style.display = 'block';
                    setTimeout(() => { if (error) error.style.display = 'none'; }, 3000);
                }
                return;
            }

            if (!isAdminAuthenticated) return;

            const toggle = e.target.closest('.toggle-switch');
            if (toggle) {
                setSyllableHighlighter(!getSyllableHighlighter());
                updateAdminContent();
            }
            const macro = e.target.closest('.custom-macro-btn');
            if (macro) {
                const chatInput = document.querySelector('.chat input, .chat textarea, .chatInput');
                if (chatInput) {
                    chatInput.value = macro.getAttribute('data-msg');
                    chatInput.dispatchEvent(new Event('input', { bubbles: true }));
                    chatInput.focus();
                    // Auto-send if possible (Enter key simulation)
                    chatInput.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', code: 'Enter', bubbles: true }));
                }
            }

            if (e.target.id === 'admin-logout-btn') {
                isAdminAuthenticated = false;
                setAdminAuth(false);
                updateAdminContent();
            }
        });
        adminPage.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && (e.target.id === 'admin-user-input' || e.target.id === 'admin-pass-input')) {
                document.getElementById('admin-login-btn').click();
            }
        });

        adminPage.addEventListener('input', (e) => {
            if (e.target.id === 'admin-theme-picker') {
                setThemeColor(e.target.value);
                updateThemeStyles();
            }
        });

        // --- Game State Tracking (Used Words & Stats) ---
        const gameObserver = new MutationObserver(() => {
            // Syllable highlighting
            if (getSyllableHighlighter()) {
                const sylEl = document.querySelector('.syllable');
                if (sylEl && !sylEl.classList.contains('highlight-syllable')) {
                    sylEl.classList.add('highlight-syllable');
                }
            }

            // --- Stats Tracking: Turn Detection ---
            const selfTurnEl = document.querySelector('.selfTurn');
            if (selfTurnEl) {
                if (!isUserTurn) {
                    isUserTurn = true;
                    turnStartTime = Date.now();
                }
            } else {
                isUserTurn = false;
            }

            // Tracking used words (JKLM specific: .word elements in player areas)
            const acceptedWords = document.querySelectorAll('.player .word');
            acceptedWords.forEach(wordEl => {
                const word = wordEl.innerText.trim().toUpperCase();
                if (word.length > 0 && !usedWords.includes(word)) {
                    if (!wordEl.dataset.tracked) {
                        wordEl.dataset.tracked = "true";
                        
                        // --- Stats Tracking: Word Submission ---
                        const isSelfWord = wordEl.closest('.selfTurn');
                        if (isSelfWord && turnStartTime > 0) {
                            const responseTime = Date.now() - turnStartTime;
                            const stats = getStats();
                            stats.totalWords++;
                            if (word.length > stats.longestWord.length) stats.longestWord = word;
                            stats.responseTimes.push(responseTime);
                            // Keep only last 100 times for average to stay relevant
                            if (stats.responseTimes.length > 100) stats.responseTimes.shift();
                            setStats(stats);
                            updateStatsContent();
                            turnStartTime = 0; // Reset after capture
                        }

                        setTimeout(() => {
                            if (!usedWords.includes(word)) {
                                usedWords.push(word);
                                updateUsedWordsUI();
                            }
                        }, 500);
                    }
                }
            });

            // Round reset detection (if syllable disappears or game state changes)
            const gameVisible = !!document.querySelector('.canvasArea') || !!document.querySelector('.syllable');
            if (!gameVisible && usedWords.length > 0) {
                usedWords = [];
                updateUsedWordsUI();
            }
        });
        gameObserver.observe(document.body, { childList: true, subtree: true, characterData: true });

        const updateUsedWordsUI = () => {
            const list = document.getElementById('used-words-list');
            if (!list) return;
            const lang = getLanguage();
            const t = translations[lang] || translations['Deutsch'];
            if (usedWords.length === 0) {
                list.innerText = t.usedWordsEmpty;
            } else {
                list.innerHTML = usedWords.map(w => `<span style="background: #222; padding: 2px 5px; border-radius: 3px;">${w}</span>`).join(' ');
            }
        };

        GM_addValueChangeListener('spaceToHyphenEnabled', () => updateKbContent());
        GM_addValueChangeListener('selectedLanguage', () => { updateLangContent(); updateKbContent(); updateDictContent(); updateAdminContent(); updateUsedWordsUI(); });
        GM_addValueChangeListener('dictLanguage', () => { dictionaryLoaded = false; loadDictionary(true).then(() => updateDictContent()); });
        GM_addValueChangeListener('sidebarWidth', (n, o, nv) => updateSidebarWidths(nv));
        GM_addValueChangeListener('themeColor', () => updateThemeStyles());

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && [catTab, flagTab, dictTab, adminTab].some(t => t.classList.contains('active'))) {
                window.closeCustomTabs();
            }
        });
    };

    // --- Keydown Logic (Spacebar to Hyphen) ---
    document.addEventListener('keydown', (e) => {
        const enabled = getEnabled();
        const chatEnabled = getChatEnabled();
        if (!enabled && !chatEnabled) return;

        if (e.code === 'Space' || e.key === ' ') {
            const active = document.activeElement;
            if (!active || !(active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;

            // Kontext-Erkennung
            const isChatContext = active.closest('.chat') || 
                                 active.placeholder?.toLowerCase().includes('chat') || 
                                 active.classList.contains('chatInput') ||
                                 active.id === 'dict-msg-input';
            
            // JKLM-spezifisch: Bist du am Zug?
            const isSelfTurn = !!document.querySelector('.selfTurn');
            
            let shouldConvert = false;
            if (isChatContext) {
                // Im Chat nur konvertieren, wenn Chat-Einstellung aktiv ist
                if (chatEnabled) shouldConvert = true;
            } else {
                // Im Spiel nur konvertieren, wenn Game-Einstellung aktiv ist UND man am Zug ist
                if (enabled && isSelfTurn) shouldConvert = true;
            }

            if (shouldConvert) {
                e.preventDefault(); 
                e.stopImmediatePropagation();
                try { if (!document.execCommand('insertText', false, '-')) throw new Error(); } catch (err) {
                    const start = active.selectionStart, end = active.selectionEnd;
                    active.value = active.value.substring(0, start) + '-' + active.value.substring(end);
                    active.selectionStart = active.selectionEnd = start + 1;
                    active.dispatchEvent(new Event('input', { bubbles: true }));
                }
            }
        }
    }, true);

    const checkInit = new MutationObserver(() => { if (document.querySelector('.navigation, .tabs')) { init(); checkInit.disconnect(); } });
    checkInit.observe(document.body, { childList: true, subtree: true });
})();
