                return;
            }

            if (!isAdminAuthenticated) return;

            const row = e.target.closest('.settings-row');
            if (row) {
                // Verhindere re-render, wenn nur auf ein Select-Feld oder Button geklickt wurde
                if (e.target.tagName === 'SELECT' || e.target.tagName === 'BUTTON' || e.target.classList.contains('custom-key-select')) {
                    return;
                }

                if (row.id === 'toggle-sound') {
                    setSoundEnabled(!getSoundEnabled());
                } else if (row.id === 'toggle-tab-sound') {
                    setTabSoundEnabled(!getTabSoundEnabled());
                } else if (row.id === 'toggle-sound2') {
                    setSound2Enabled(!getSound2Enabled());
                } else if (row.id === 'toggle-mini-mode') {
                    setMiniMode(!getMiniMode());
                    updateThemeStyles();
                }
                updateAdminContent();
            }
            const macro = e.target.closest('.custom-macro-btn');
            const removeBtn = e.target.closest('.custom-macro-remove');
            const presetBtn = e.target.closest('.custom-preset-btn');

            if (presetBtn) {
                const themeName = presetBtn.getAttribute('data-theme-name');
                const colors = themePresets[themeName];
                if (colors) {
                    setThemeColor(colors.theme);
                    setBgColor(colors.bg);
                    setCurrentThemeName(themeName);
                    updateThemeStyles();
                    updateAdminContent();
                }
                return;
            }

            if (removeBtn) {
                e.stopPropagation();
                const index = parseInt(removeBtn.getAttribute('data-index'), 10);
                const macros = getMacros();
                macros.splice(index, 1);
                setMacros(macros);
                updateAdminContent();
                return;
            }

            if (macro && macro.id !== 'admin-macro-add-btn') {
                sendToChat(macro.getAttribute('data-msg'));
            }

            if (e.target.id === 'admin-macro-add-btn') {
                const input = document.getElementById('admin-macro-input');
                const val = input.value.trim();
                if (val) {
                    const macros = getMacros();
                    if (!macros.includes(val)) {
                        macros.push(val);
                        setMacros(macros);
                        updateAdminContent();
                    }
                }
            }

            if (e.target.id === 'admin-logout-btn') {
                isAdminAuthenticated = false;
                setAdminAuth(false);
                adminTab.style.display = 'none';
                window.closeCustomTabs();
                updateAdminContent();
            }

            if (e.target.id === 'sound-key-select' || e.target.id === 'sound-key-select2') {
                const isSecond = e.target.id === 'sound-key-select2';
                const btn = e.target;
                btn.textContent = '...';
                btn.classList.add('listening');

                const keydownHandler = (keyEvent) => {
                    keyEvent.preventDefault();
                    const newKey = keyEvent.key;
                    if (isSecond) setSoundKey2(newKey);
                    else setSoundKey(newKey);
                    btn.textContent = newKey;
                    btn.classList.remove('listening');
                    document.removeEventListener('keydown', keydownHandler, { capture: true });
                };

                document.addEventListener('keydown', keydownHandler, { once: true, capture: true });
            }

            if (e.target.id === 'test-tab-sound' || e.target.id === 'test-tab-sound2') {
                const soundData = e.target.id === 'test-tab-sound2' ? getCustomSound2() : getCustomSound();
                if (soundData) {
                    const audio = new Audio(soundData);
                    audio.play();
                }
            }

            if (e.target.id === 'save-tab-sound' || e.target.id === 'save-tab-sound2') {
                const isSecond = e.target.id === 'save-tab-sound2';
                const fileEl = document.getElementById(isSecond ? 'tab-sound-file2' : 'tab-sound-file');
                const file = fileEl.files[0];
                if (!file) return;

                if (file.size > 1024 * 1024) { // 1MB Limit
                    alert(translations['Englisch'].adminSoundError);
                    return;
                }

                const reader = new FileReader();
                reader.onload = (event) => {
                    if (isSecond) setCustomSound2(event.target.result);
                    else setCustomSound(event.target.result);
                    alert(translations['Englisch'].adminSoundSuccess);
                };
                reader.readAsDataURL(file);
            }

            if (e.target.id === 'cpp-confirm-file') {
                const t = translations['Englisch'];
                const fileEl = document.getElementById('cpp-file');
                const file = fileEl.files[0];
                if (file == null) return;

                const blobURL = URL.createObjectURL(file);
                fetch(blobURL)
                    .then(res => res.arrayBuffer())
                    .then(buf => new Uint8Array(buf))
                    .then(arr => {
                        const encoded = base64EncArr(arr);
                        if (encoded.length > 10000) {
                            alert(t.adminCppError);
                            return;
                        }

                        // JKLM Settings Integration
                        if (window.settings) {
                            window.settings.picture = encoded;
                            if (typeof window.saveSettings === 'function') window.saveSettings();
                            alert(t.adminCppSuccess);
                            location.reload();
                        } else {
                            // Fallback if settings not globally available
                            const jklmSettings = JSON.parse(localStorage.getItem('jklmSettings') || '{}');
                            jklmSettings.picture = encoded;
                            localStorage.setItem('jklmSettings', JSON.stringify(jklmSettings));
                            alert(t.adminCppSuccess);
                            location.reload();
                        }
                    });
            }
        });

        adminPage.addEventListener('change', (e) => {
            if (e.target.id === 'admin-font-select') {
                setCustomFont(e.target.value);
                updateThemeStyles();
            }
        });

        adminPage.addEventListener('contextmenu', (e) => {
            if (!isAdminAuthenticated) return;
            const macro = e.target.closest('.custom-macro-btn');
            if (macro && macro.id !== 'admin-macro-add-btn') {
                e.preventDefault();
                const index = parseInt(macro.getAttribute('data-index'), 10);
                const macros = getMacros();
                macros.splice(index, 1);
                setMacros(macros);
                updateAdminContent();
            }
        });

        adminPage.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && (e.target.id === 'admin-user-input' || e.target.id === 'admin-pass-input')) {
                document.getElementById('admin-login-btn').click();
            }
        });

        adminPage.addEventListener('input', (e) => {
            if (e.target.id === 'admin-theme-picker') {
                setThemeColor(e.target.value);
                setCurrentThemeName('Custom');
                updateThemeStyles();
                updateAdminContent();
            }
            if (e.target.id === 'admin-bg-picker') {
                setBgColor(e.target.value);
                setCurrentThemeName('Custom');
                updateThemeStyles();
                updateAdminContent();
            }
        });

        // --- Game State Tracking (Used Words & Stats) ---
        const gameObserver = new MutationObserver(() => {
            // Automatische Silben-Erkennung
            const sylEl = document.querySelector('.syllable');
            if (sylEl) {
                const currentSyl = sylEl.innerText.trim().toLowerCase();
                if (currentSyl !== lastDetectedSyllable) {
                    lastDetectedSyllable = currentSyl;

                    // Wenn wir im Dictionary-Tab sind, aktualisieren wir die Vorschläge automatisch
                    const dictInput = document.getElementById('dict-msg-input');
                    if (dictInput && document.getElementById('dict-btn').classList.contains('active')) {
                        dictInput.value = currentSyl.toUpperCase();
                        updateSuggestions();
                    }

                    // Highlighte die Silbe, wenn die Einstellung aktiv ist
                    if (getSyllableHighlighter()) {
                        sylEl.classList.add('highlight-syllable');
                    }
                }
            }

            // JKLM-spezifisch: Bist du am Zug?
            const isSelfTurn = !!document.querySelector('.selfTurn');
            if (isSelfTurn && !window.lastTurnState) {
                playSound('turn');
            }
            window.lastTurnState = isSelfTurn;

            // Round reset detection (if syllable disappears or game state changes)
            const gameVisible = !!document.querySelector('.canvasArea') || !!document.querySelector('.syllable');

            if (gameVisible && !isGameRunning) {
                isGameRunning = true;
            } else if (!gameVisible && isGameRunning) {
                isGameRunning = false;
            }
        });
        gameObserver.observe(document.body, { childList: true, subtree: true, characterData: true });

        GM_addValueChangeListener('spaceToHyphenEnabled', () => updateKbContent());
        GM_addValueChangeListener('dictLanguage', () => { dictionaryLoaded = false; loadDictionary(true).then(() => updateDictContent()); });
        GM_addValueChangeListener('sidebarWidth', (n, o, nv) => updateSidebarWidths(nv));
        GM_addValueChangeListener('themeColor', () => updateThemeStyles());
        GM_addValueChangeListener('bgColor', () => updateThemeStyles());

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && [catTab, dictTab, adminTab].some(t => t.classList.contains('active'))) {
                window.closeCustomTabs();
            }
        });
    };

    // --- Keydown Logic (Spacebar to Hyphen & F1 for GG) ---
    document.addEventListener('keydown', (e) => {
        // F1 Macro: GG
        if (e.key === 'F1') {
            e.preventDefault();
            sendToChat('GG');
            return;
        }

        // Sound Trigger: User Configurable Keys
        if (e.key === getSoundKey() || e.key === getSoundKey2()) {
            const isSecond = e.key === getSoundKey2();
            const enabled = isSecond ? getSound2Enabled() : getTabSoundEnabled();
            if (enabled) {
                const soundData = isSecond ? getCustomSound2() : getCustomSound();
                if (soundData) {
                    e.preventDefault();
                    const audio = new Audio(soundData);
                    audio.play();
                }
            }
            return;
        }

        const enabled = getEnabled();
        const chatEnabled = getChatEnabled();
        if (!enabled && !chatEnabled) return;

        if (e.code === 'Space' || e.key === ' ') {
            const active = document.activeElement;
            if (!active || !(active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable)) return;

            // Kontext-Erkennung
            const isChatContext = active.closest('.chat') ||
                active.placeholder?.toLowerCase().includes('chat') ||
                active.classList.contains('chatInput') ||
                active.id === 'dict-msg-input';

            // JKLM-spezifisch: Bist du am Zug?
            const isSelfTurn = !!document.querySelector('.selfTurn');

            let shouldConvert = false;
            if (isChatContext) {
                // Im Chat nur konvertieren, wenn Chat-Einstellung aktiv ist
                if (chatEnabled) shouldConvert = true;
            } else {
                // Im Spiel nur konvertieren, wenn Game-Einstellung aktiv ist UND man am Zug ist
                if (enabled && isSelfTurn) shouldConvert = true;
            }

            if (shouldConvert) {
                e.preventDefault();
                e.stopImmediatePropagation();
                try { if (!document.execCommand('insertText', false, '-')) throw new Error(); } catch (err) {
                    const start = active.selectionStart, end = active.selectionEnd;
                    active.value = active.value.substring(0, start) + '-' + active.value.substring(end);
                    active.selectionStart = active.selectionEnd = start + 1;
                    active.dispatchEvent(new Event('input', { bubbles: true }));
                }
            }
        }
    }, true);

    const checkInit = new MutationObserver(() => { if (document.querySelector('.navigation, .tabs')) { init(); checkInit.disconnect(); } });
    checkInit.observe(document.body, { childList: true, subtree: true });
})();
